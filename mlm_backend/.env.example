# -----------------------------------------------------------------------------
# Copy to .env — default below is LOCAL development with SQLite + LocMem cache.
# -----------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=config.settings.development

# Use SQLite file at mlm_backend/db.sqlite3 (see config/settings/development.py)
USE_SQLITE=true

SECRET_KEY=change-me-in-production
DEBUG=True

# Optional: separate HMAC key for agreement acceptance proof PDFs (defaults to SECRET_KEY).
# AGREEMENT_PROOF_SIGNING_SECRET=

# Host header must match: calling http://192.168.x.x:8000 fails until you list that hostname/IP here (comma-separated, no spaces).
ALLOWED_HOSTS=localhost,127.0.0.1

FRONTEND_BASE_URL=http://localhost:3000
KYC_INVITE_WEB_PATH=/compliance
# Optional mobile deep link for MSG91 SMS (falls back to web URL)
KYC_INVITE_MOBILE_URL=
KYC_INVITE_TOKEN_MAX_AGE_DAYS=30
# Browser clients on another PC: include origins that use your LAN IP + port (e.g. http://192.168.1.50:3000).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production over HTTP (e.g. local Docker): must be set so admin session cookie works.
USE_INSECURE_COOKIES=1
# Serve MEDIA through Django routes (local Docker/testing). Keep 0 in real production.
SERVE_MEDIA=0

# Include OTP in JSON + server logs (demo/dev). Set EXPOSE_OTP_IN_RESPONSE=false for real production.
EXPOSE_OTP_IN_RESPONSE=true
# OTP send throttle per phone/email (Django cache TTL = window).
OTP_SEND_MAX_PER_WINDOW=3
OTP_SEND_WINDOW_SECONDS=600
# Comma-separated origins for Django admin POST (extends defaults in production.py if unset).
# CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# Company root referral (createsuperuser default referral_code); signups may use this.
DEFAULT_COMPANY_REFERRAL_CODE=Admin
COMPANY_SUPERUSER_MEMBER_ID=SYS000001

JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_PAYOUT_KEY_ID=
RAZORPAY_PAYOUT_KEY_SECRET=

SMS_PROVIDER_API_KEY=
AADHAAR_OTP_API_KEY=

GST_NUMBER=
PAN_NUMBER=
COMPANY_NAME=Just 200
# Printed on GST invoice PDF (multiline COMPANY_ADDRESS OK in .env when quoted).
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_WEBSITE=
# Optional multiline quoted text blocks for invoice PDF footer/payment column.
INVOICE_PAYMENT_DETAILS=
INVOICE_TERMS_AND_CONDITIONS=

AZURE_STORAGE_CONNECTION_STRING=
AZURE_CONTAINER_NAME=ebooks

# -----------------------------------------------------------------------------
# Docker Compose (mlm_backend/docker/docker-compose.yml)
# - compose sets DB_* + USE_SQLITE=false for web/celery — host .env may keep USE_SQLITE=true
#   for local manage.py; containers still use MySQL from the compose env block.
# -----------------------------------------------------------------------------
# USE_SQLITE=false
# DEBUG=False
# ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx
# DB_ENGINE=django.db.backends.mysql
# DB_HOST=db
# DB_NAME=mlm_db
# DB_USER=mlm_user
# DB_PASSWORD=mlm_pass
# DB_PORT=3306
# REDIS_URL=redis://redis:6379/0
