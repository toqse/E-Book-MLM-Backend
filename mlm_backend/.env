# =============================================================================
# Local development — SQLite (run from mlm_backend: python manage.py runserver)
# Requires: USE_SQLITE=true (uses mlm_backend/db.sqlite3, LocMem cache, Celery eager)
# =============================================================================
DJANGO_SETTINGS_MODULE=config.settings.development
USE_SQLITE=true

SECRET_KEY=docker-dev-secret-change-for-real-deployments
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.42

FRONTEND_BASE_URL=http://localhost:8080
