# Docker / production-style local run (used by docker-compose)
SECRET_KEY=docker-dev-secret-change-for-real-deployments
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,web,nginx

USE_INSECURE_COOKIES=1

DB_NAME=mlm_db
DB_USER=mlm_user
DB_PASSWORD=mlm_pass
DB_HOST=db
DB_PORT=3306

REDIS_URL=redis://redis:6379/0

FRONTEND_BASE_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
